{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "BUNGIE_API_KEY",
    "BUNGIE_CLIENT_ID",
    "BUNGIE_CLIENT_SECRET",
    "OAUTH_REDIRECT_URI_WEB",
    "VITE_BUNGIE_API_KEY",
    "VITE_BUNGIE_CLIENT_ID",
    "VITE_BUNGIE_CLIENT_SECRET",
    "VITE_OAUTH_REDIRECT_URI"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".expo/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "cache": false
    },
    "test:e2e:mobile": {
      "cache": false
    }
  }
}

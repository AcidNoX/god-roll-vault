  },
  "devDependencies": {
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "26.1.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vitest": "catalog:"
  }
}

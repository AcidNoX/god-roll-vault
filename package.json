{
  "name": "god-roll-vault",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test -- --coverage",
    "test:e2e": "turbo test:e2e",
    "test:e2e:mobile": "turbo test:e2e:mobile",
    "validate-data": "pnpm --filter @god-roll-vault/destiny-data validate-data",
    "validate-design-tokens": "node scripts/validate-design-tokens.mjs",
    "validate-design-screens": "node scripts/validate-design-screens.mjs",
    "generate-inventory-preview": "pnpm --filter @god-roll-vault/destiny-data generate-inventory-preview"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "turbo": "2.10.0"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "react-dom": "19.0.0"
    }
  }
}

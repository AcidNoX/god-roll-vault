{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["meta", "screens", "annotations"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["figma", "desktopWidth"]
    },
    "screens": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "name", "figmaFrame", "regions"]
      }
    },
    "annotations": { "type": "object" }
  }
}

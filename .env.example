# Bungie.net — create app(s) at https://www.bungie.net/en/Application
# See docs/bungie-setup.md (web + mobile need separate apps — one redirect URL each)
BUNGIE_API_KEY=
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=

# OAuth redirect URIs (must match the Bungie app you registered for this platform)
OAUTH_REDIRECT_URI_WEB=https://127.0.0.1:3000/auth/callback
OAUTH_REDIRECT_URI_MOBILE=godrollvault://auth/callback
